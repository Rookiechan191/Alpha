# Copy this file to .env and fill in your key.
# cp .env.example .env

# Required: Groq API key (free at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Optional overrides (defaults shown)
LLM_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
TOP_K_RETRIEVE=20
TOP_K_RERANK=5

# Groq pricing for llama-3.3-70b-versatile (USD per token)
PRICE_PER_INPUT_TOKEN=0.00000059
PRICE_PER_OUTPUT_TOKEN=0.00000079
