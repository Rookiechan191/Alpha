# Copy this file to .env and fill in your key.
# cp .env.example .env

# Required: Anthropic API key for Claude Haiku (generation step only)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional overrides (defaults shown)
LLM_MODEL=claude-haiku-4-5-20251001
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
TOP_K_RETRIEVE=20
TOP_K_RERANK=5

# Pricing (USD per token) -- update if model/pricing changes
PRICE_PER_INPUT_TOKEN=0.000001
PRICE_PER_OUTPUT_TOKEN=0.000005
